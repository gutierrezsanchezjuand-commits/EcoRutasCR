<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Agregar punto · EcoRutas CR</title>
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#0F2419">
<link rel="icon" href="icons/icon-192.png">
<link rel="apple-touch-icon" href="icons/icon-192.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg-deep:#0F2419;
    --bg-panel:#122B1D;
    --ev:#20C9A6;
    --ev-dim:rgba(32,201,166,0.16);
    --gas:#F0973B;
    --gas-dim:rgba(240,151,59,0.18);
    --line-light:rgba(245,242,232,0.14);
    --text-light:#EAF3EC;
    --text-light-dim:#A9C2B2;
    --font-display:'Fraunces',serif;
    --font-body:'Inter',system-ui,sans-serif;
    --font-mono:'JetBrains Mono',monospace;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    min-height:100vh;
    background:var(--bg-deep);
    color:var(--text-light);
    font-family:var(--font-body);
    display:flex;
    justify-content:center;
    padding:48px 20px;
  }
  .card{
    width:100%;
    max-width:480px;
  }
  .back-link{
    display:inline-flex; align-items:center; gap:6px;
    font-size:13px; color:var(--text-light-dim); text-decoration:none;
    margin-bottom:22px;
  }
  .back-link:hover{color:var(--text-light);}
  h1{
    font-family:var(--font-display);
    font-weight:700;
    font-size:26px;
    margin:0 0 6px;
    letter-spacing:-0.01em;
  }
  .sub{
    color:var(--text-light-dim);
    font-size:13.5px;
    margin:0 0 28px;
    line-height:1.5;
  }
  form{
    background:var(--bg-panel);
    border:1px solid var(--line-light);
    border-radius:16px;
    padding:26px;
    display:flex;
    flex-direction:column;
    gap:16px;
  }
  label{
    font-size:12px;
    font-weight:600;
    color:var(--text-light-dim);
    text-transform:uppercase;
    letter-spacing:.04em;
    display:block;
    margin-bottom:6px;
  }
  input, select{
    width:100%;
    padding:11px 13px;
    border-radius:9px;
    border:1px solid var(--line-light);
    background:rgba(255,255,255,0.05);
    color:var(--text-light);
    font-family:var(--font-body);
    font-size:14px;
    outline:none;
  }
  input:focus, select:focus{border-color:var(--ev);}
  .type-row{display:flex; gap:10px;}
  .type-opt{
    flex:1;
    display:flex; align-items:center; justify-content:center; gap:7px;
    padding:11px; border-radius:9px;
    border:1px solid var(--line-light);
    cursor:pointer;
    font-size:13px; font-weight:600;
    color:var(--text-light-dim);
  }
  .type-opt input{width:auto; margin:0;}
  .type-opt.ev-active{background:var(--ev-dim); border-color:var(--ev); color:var(--ev);}
  .type-opt.gas-active{background:var(--gas-dim); border-color:var(--gas); color:var(--gas);}
  .row2{display:flex; gap:12px;}
  .row2 > div{flex:1;}
  .geo-btn{
    display:flex; align-items:center; justify-content:center; gap:7px;
    padding:9px; border-radius:8px;
    border:1px dashed var(--line-light);
    background:transparent;
    color:var(--text-light-dim);
    font-size:12px; font-weight:600;
    cursor:pointer;
    margin-top:6px;
  }
  .geo-btn:hover{border-color:var(--ev); color:var(--ev);}
  .submit-btn{
    margin-top:6px;
    padding:13px;
    border-radius:10px;
    border:none;
    background:var(--ev);
    color:#06231C;
    font-weight:700;
    font-size:14px;
    cursor:pointer;
  }
  .submit-btn:hover{filter:brightness(1.08);}
  .submit-btn:disabled{opacity:.6; cursor:progress;}
  .msg{
    font-size:13px;
    padding:12px 14px;
    border-radius:9px;
    display:none;
  }
  .msg.show{display:block;}
  .msg.ok{background:var(--ev-dim); color:var(--ev);}
  .msg.err{background:rgba(240,80,80,0.16); color:#FF8A8A;}
  .coords-hint{font-family:var(--font-mono); font-size:11px; color:var(--text-light-dim); margin-top:4px;}
</style>
</head>
<body>
<div class="card">
  <a class="back-link" href="index.html">← Volver al mapa</a>
  <h1>Agregar un punto</h1>
  <p class="sub">Sumá una estación de carga eléctrica o de gas LP. Se guarda directo en la base de datos y aparece en el mapa al recargar.</p>

  <form id="stationForm">
    <div>
      <label>Tipo de punto</label>
      <div class="type-row">
        <label class="type-opt" id="optEv">
          <input type="radio" name="type" value="ev" checked> ⚡ Eléctrica
        </label>
        <label class="type-opt" id="optGas">
          <input type="radio" name="type" value="gas"> ⛽ Gas LP
        </label>
      </div>
    </div>

    <div>
      <label for="name">Nombre del punto</label>
      <input id="name" type="text" placeholder="Ej: Tomza Autogas - San Rafael" required>
    </div>

    <div class="row2">
      <div>
        <label for="network">Red / marca</label>
        <input id="network" type="text" placeholder="Ej: Tomza, EGO, ICE..." required>
      </div>
      <div>
        <label for="info">Detalle</label>
        <input id="info" type="text" placeholder="Ej: 1x DC 50kW / GLP vehicular" required>
      </div>
    </div>

    <div>
      <label for="address">Dirección</label>
      <input id="address" type="text" placeholder="Ej: San Rafael, Alajuela" required>
    </div>

    <div class="row2">
      <div>
        <label for="lat">Latitud</label>
        <input id="lat" type="number" step="any" placeholder="Ej: 10.0163" required>
      </div>
      <div>
        <label for="lng">Longitud</label>
        <input id="lng" type="number" step="any" placeholder="Ej: -84.2116" required>
      </div>
    </div>
    <button type="button" class="geo-btn" id="geoBtn">📍 Usar mi ubicación actual</button>
    <div class="coords-hint">Tip: en Google Maps, clic derecho sobre el punto exacto copia las coordenadas.</div>

    <button type="submit" class="submit-btn" id="submitBtn">Guardar punto</button>
    <div class="msg" id="msg"></div>
  </form>
</div>

<script src="config.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>
(function(){
  const supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

  const form = document.getElementById('stationForm');
  const msg = document.getElementById('msg');
  const submitBtn = document.getElementById('submitBtn');
  const optEv = document.getElementById('optEv');
  const optGas = document.getElementById('optGas');

  function syncTypeStyle(){
    const checked = form.querySelector('input[name="type"]:checked').value;
    optEv.classList.toggle('ev-active', checked === 'ev');
    optGas.classList.toggle('gas-active', checked === 'gas');
  }
  form.querySelectorAll('input[name="type"]').forEach(r => r.addEventListener('change', syncTypeStyle));
  syncTypeStyle();

  document.getElementById('geoBtn').addEventListener('click', () => {
    if(!navigator.geolocation){ alert('Tu navegador no soporta geolocalización.'); return; }
    navigator.geolocation.getCurrentPosition(
      pos => {
        document.getElementById('lat').value = pos.coords.latitude.toFixed(6);
        document.getElementById('lng').value = pos.coords.longitude.toFixed(6);
      },
      () => alert('No pudimos obtener tu ubicación.')
    );
  });

  function showMsg(text, ok){
    msg.textContent = text;
    msg.className = 'msg show ' + (ok ? 'ok' : 'err');
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    if(!SUPABASE_URL || SUPABASE_URL.includes('TU_SUPABASE')){
      showMsg('Falta configurar config.js con tu URL y API key de Supabase.', false);
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Guardando...';

    const payload = {
      type: form.querySelector('input[name="type"]:checked').value,
      name: document.getElementById('name').value.trim(),
      network: document.getElementById('network').value.trim(),
      info: document.getElementById('info').value.trim(),
      address: document.getElementById('address').value.trim(),
      lat: parseFloat(document.getElementById('lat').value),
      lng: parseFloat(document.getElementById('lng').value),
    };

    const { error } = await supabaseClient.from('estaciones').insert(payload);

    submitBtn.disabled = false;
    submitBtn.textContent = 'Guardar punto';

    if(error){
      showMsg('No se pudo guardar: ' + error.message, false);
    } else {
      showMsg('¡Listo! El punto se guardó. Ya podés volver al mapa.', true);
      form.reset();
      syncTypeStyle();
    }
  });
})();

if('serviceWorker' in navigator){
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('service-worker.js').catch(console.error);
  });
}
</script>
</body>
</html>
